{
  "buildCommand": "vite build",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "dist",
  "functions": {
    "api/server.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
