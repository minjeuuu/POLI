{
  "entities": {
    "Message": {
      "title": "Chat Message",
      "description": "A message in a chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "chatId", "senderId", "senderName", "text", "createdAt"]
    },
    "Post": {
      "title": "Community Post",
      "description": "A post in the social feed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "content": { "type": "string" },
        "likes": { "type": "number" },
        "comments": { "type": "array" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "authorId", "authorName", "content", "likes", "comments", "createdAt"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Stores chat messages."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Stores community posts."
    }
  }
}
